rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Read: yourself, or your partner once you are both members of the same
      // couple. There is intentionally NO general "any signed-in user" clause.
      // The join handshake no longer reads the inviter's user doc — the
      // "inviter already partnered" guard moved to the cross-user update rule
      // below (coupleId == null), so nothing legitimately needs to read a
      // stranger's profile.
      allow read: if request.auth.uid == userId
        || (resource.data.coupleId != null
            && request.auth.uid in get(
                 /databases/$(database)/documents/couples/$(resource.data.coupleId)
               ).data.members);
      allow create, delete: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId ||
        // Cross-user coupleId write is allowed for ONE operation only: the join
        // handshake, where the joiner sets the inviter's coupleId to a pending
        // couple the inviter is a member of. Disconnect is now fully
        // server-side (disconnectPartner / deleteAccount use the Admin SDK), so
        // there is no client-side cross-user disconnect write.
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['coupleId']) &&
         resource.data.coupleId == null &&
         request.resource.data.coupleId != null &&
         get(/databases/$(database)/documents/couples/$(request.resource.data.coupleId)).data.status == 'pending' &&
         userId in get(/databases/$(database)/documents/couples/$(request.resource.data.coupleId)).data.members);
    }

    // ── Couples ───────────────────────────────────────────────────────────────
    match /couples/{coupleId} {
      // Create is server-only: the createInvite Cloud Function creates the
      // pending couple doc with the Admin SDK. The client only joins (update)
      // or cancels (delete) an existing couple — it never creates one. This
      // also means clients cannot seed a server-owned field like
      // subscriptionTier at creation.
      allow create: if false;

      // Read: existing members, OR anyone authenticated when the couple is
      // still pending with a live invite — the joiner must read the doc to
      // verify status before committing.
      allow read: if request.auth != null && (
        request.auth.uid in resource.data.members ||
        (resource.data.status == 'pending' &&
         resource.data.inviteCode != null &&
         exists(/databases/$(database)/documents/invites/$(resource.data.inviteCode)))
      );

      // Update: existing members (normal edits), OR the join operation:
      //   - couple is still pending with a live invite
      //   - requester is adding only themselves (existing members stay)
      //   - requester ends up in the new members list
      allow update: if request.auth != null
        // subscriptionTier is server-owned — no client update may change it.
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['subscriptionTier'])
        && (
        request.auth.uid in resource.data.members ||
        (resource.data.status == 'pending' &&
         resource.data.inviteCode != null &&
         exists(/databases/$(database)/documents/invites/$(resource.data.inviteCode)) &&
         request.resource.data.members.hasAll(resource.data.members) &&
         request.auth.uid in request.resource.data.members)
      );

      // Delete: existing members only (used by cancelInvite).
      allow delete: if request.auth != null &&
        request.auth.uid in resource.data.members;

      // Subcollections: settings, lastTime, weeklyPlan, …
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(
            /databases/$(database)/documents/couples/$(coupleId)
          ).data.members;
      }
    }

    // ── Invites ───────────────────────────────────────────────────────────────
    // GET only, by exact code (the doc ID). The invite code is a shared pairing
    // secret; allowing LIST/query would let any signed-in user enumerate every
    // live code and join a stranger's pending couple. joinByCode() and
    // cancelInvite() only ever read a single invite by its code — a direct
    // document get, which this allows.
    //
    // Create is server-only: the createInvite Cloud Function writes invite docs
    // with the Admin SDK (which bypasses these rules). The client never creates
    // invites directly, so client creates are denied outright.
    //
    // Delete: invite creator, or an existing member of the couple (cancelInvite).
    match /invites/{inviteCode} {
      allow get: if request.auth != null;
      allow list: if false;
      allow create: if false;
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.fromUserId
        || request.auth.uid in get(
             /databases/$(database)/documents/couples/$(resource.data.coupleId)
           ).data.members
      );
    }

    // ── Ideas ─────────────────────────────────────────────────────────────────
    // All authenticated users can read idea documents (to fetch coverImageUrl).
    // Only the admin can write (upload cover URL after image upload to Storage).
    match /ideas/{ideaId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == '1RTxZHUV1NbvNlFsXhwl5LeEgFw1';
    }
  }
}
